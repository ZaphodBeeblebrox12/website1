# Django Settings
# =============================================================================

# Django secret key (REQUIRED - used for cryptographic signing)
# Generate a new one with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=eugx+m)tr+2(79at_&cv9wb5z&485qia=@tf2vzf^ioe)em+@#

# Debug mode (optional, default: False in production, True in development)
# Set to True for development, False for production
DEBUG=True

# Database Configuration
# =============================================================================

# Database URL (optional, default: sqlite:///db.sqlite3)
# Examples:
#   SQLite: sqlite:///db.sqlite3
#   PostgreSQL: postgres://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Redis Configuration (for Celery - placeholder for Phase 1)
# =============================================================================

# Redis URL (optional, default: redis://localhost:6379/0)
# Used for Celery broker and result backend
REDIS_URL=redis://localhost:6379/0

# Security & Hosting
# =============================================================================

# Allowed hosts (REQUIRED - comma separated list of domains)
# Examples: localhost,127.0.0.1,mydomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

