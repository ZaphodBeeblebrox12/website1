# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development

# Database (SQLite for Phase 1, Postgres ready)
DATABASE_URL=sqlite:///db.sqlite3

# Telegram Bot Configuration
# Get token from @BotFather: https://t.me/botfather
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Bot username WITHOUT the @ symbol (REQUIRED for Login Widget)
# Example: if your bot is @MyAwesomeBot, use: TELEGRAM_BOT_USERNAME=MyAwesomeBot
TELEGRAM_BOT_USERNAME=your-bot-username-here

# Redis (for Celery - placeholder for Phase 1)
REDIS_URL=redis://localhost:6379/0

# Allowed Hosts (comma separated)
ALLOWED_HOSTS=localhost,127.0.0.1
